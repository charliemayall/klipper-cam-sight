    file_paths: dict[str, str]
    datapath: Incomplete
    gcode_metadata: Incomplete
    sync_lock: Incomplete
    fs_observer: Incomplete
    scheduled_notifications: dict[str, asyncio.TimerHandle]
    fixed_path_args: dict[str, Any]
    queue_gcodes: bool
    check_klipper_path: Incomplete
    def __init__(self, config: ConfigHelper) -> None: ...
    def start_file_observer(self) -> None: ...
    def validate_gcode_path(self, gc_path: str) -> None: ...
    def register_data_folder(self, folder_name: str, full_access: bool = False) -> pathlib.Path: ...
    def disable_write_access(self) -> None: ...
    def check_write_enabled(self) -> None: ...
    def register_directory(self, root: str, path: str | None, full_access: bool = False) -> bool: ...
    def check_reserved_path(self, req_path: StrOrPath, need_write: bool, raise_error: bool = True) -> bool: ...
    def add_reserved_path(self, name: str, res_path: StrOrPath, read_access: bool = True) -> bool: ...
    def get_directory(self, root: str = 'gcodes') -> str: ...
    def get_registered_dirs(self) -> list[str]: ...
    def get_fixed_path_args(self) -> dict[str, Any]: ...
    def get_relative_path(self, root: str, full_path: str) -> str: ...
    def get_full_path(self, root: str, relative_path: str) -> pathlib.Path: ...
