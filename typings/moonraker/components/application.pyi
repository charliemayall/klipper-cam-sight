class MoonrakerApp:
    server: Incomplete
    json_rpc: Incomplete
    http_server: HTTPServer | None
    secure_server: HTTPServer | None
    template_cache: dict[str, JinjaTemplate]
    registered_base_handlers: list[str]
    max_upload_size: Incomplete
    cert_path: pathlib.Path
    key_path: pathlib.Path
    internal_transport: Incomplete
    mutable_router: Incomplete
    def __init__(self, config: ConfigHelper) -> None: ...
    @property
    def route_prefix(self): ...
    def parse_endpoint(self, http_path: str) -> str: ...
    def listen(self, host: str, port: int, ssl_port: int) -> None: ...
    def get_server(self) -> Server: ...
    def https_enabled(self) -> bool: ...
    async def close(self) -> None: ...
    def register_endpoint(self, endpoint: str, request_types: list[str] | RequestType, callback: APICallback, transports: list[str] | TransportType = ..., wrap_result: bool = True, content_type: str | None = None, auth_required: bool = True, is_remote: bool = False) -> None: ...
    def register_static_file_handler(self, pattern: str, file_path: str, force: bool = False) -> None: ...
    def register_upload_handler(self, pattern: str, location_prefix: str = 'server/files') -> None: ...
    def register_websocket_handler(self, pattern: str, handler: type[WebSocketHandler]) -> None: ...
    def register_debug_endpoint(self, endpoint: str, request_types: list[str] | RequestType, callback: APICallback, transports: list[str] | TransportType = ..., wrap_result: bool = True) -> None: ...
    def remove_endpoint(self, endpoint: str) -> None: ...
    async def load_template(self, asset_name: str) -> JinjaTemplate: ...

class AuthorizedRequestHandler(tornado.web.RequestHandler):
    server: Server
    auth_required: bool
    cors_enabled: bool
    def initialize(self) -> None: ...
    def set_default_headers(self) -> None: ...
    current_user: Incomplete
    async def prepare(self) -> None: ...
    def options(self, *args, **kwargs) -> None: ...
    def get_associated_websocket(self) -> WebSocket | None: ...
    def write_error(self, status_code: int, **kwargs) -> None: ...

class AuthorizedFileHandler(tornado.web.StaticFileHandler):
    server: Server
    cors_enabled: bool
    def initialize(self, path: str, default_filename: str | None = None) -> None: ...
    def set_default_headers(self) -> None: ...
    current_user: Incomplete
    async def prepare(self) -> None: ...
    def options(self, *args, **kwargs) -> None: ...
    def write_error(self, status_code: int, **kwargs) -> None: ...

