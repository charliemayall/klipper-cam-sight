class MutableRouter(RuleRouter):
    application: Incomplete
    pattern_to_rule: dict[str, Rule]
    def __init__(self, application: tornado.web.Application) -> None: ...
    def get_target_delegate(self, target: Any, request: tornado.httputil.HTTPServerRequest, **target_params) -> MessageDelgate: ...
    def has_rule(self, pattern: str) -> bool: ...
    def add_handler(self, pattern: str, target: Any, target_params: dict[str, Any] | None = None) -> None: ...
    def remove_handler(self, pattern: str) -> None: ...

class PrimaryRouter(MutableRouter):
    verbose_logging: Incomplete
    def __init__(self, config: ConfigHelper) -> None: ...
