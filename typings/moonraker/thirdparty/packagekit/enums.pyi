from enum import Flag

class PkFlag(Flag):
    @classmethod
    def from_pkstring(cls, pkstring: str): ...
    @classmethod
    def from_index(cls, index: int): ...
    @property
    def pkstring(self) -> str: ...
    @property
    def desc(self) -> str: ...
    @property
    def index(self) -> int: ...

